# Railway Environment Variables Configuration
# Copy these to Railway dashboard: Settings > Variables

# Required - Gemini API for mockup generation
GEMINI_API_KEY=your_gemini_api_key_here

# Flask Configuration
FLASK_DEBUG=false
PORT=8000

# Optional - Authentication (set DISABLE_AUTH=false to enable)
AUTH_USER=Admin
AUTH_PASS=your_secure_password_here
DISABLE_AUTH=true

# Optional - Model selection
GEMINI_MOCKUP_MODEL=gemini-2.5-flash-image

# Note: PORT is automatically set by Railway, no need to configure
